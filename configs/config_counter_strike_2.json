{
    "sport": "Counter-Strike 2",
    "cle_groupement": "stage",
    "type_format": "elimination",
    "formats_par_stage": {
        "1": "championnat",
        "2": "championnat",
        "3": "championnat"
    },
    "poids_rounds": {
        "RO2": 1,
        "RO4": 2,
        "RO8": 3
    },
    "fichiers": {
        "athlete": {
            "nom_fichier": "counter_strike_2/player.csv",
            "mapping": {
                "id_personne": "pseudo",
                "nom": "name",
                "pseudo": "pseudo",
                "provenance": "nationality",
                "date_naissance": "birthdate",
                "role": "role",
                "equipe_actuelle": "team"
            }
        },
        "coach": {
            "nom_fichier": "counter_strike_2/coach.csv",
            "mapping": {
                "id_personne": "pseudo",
                "nom": "name",
                "provenance": "nationality",
                "equipe_actuelle": "team"
            }
        },
        "equipe": {
            "nom_fichier": "counter_strike_2/team.csv",
            "mapping": {
                "id_equipe": "team",
                "nom": "team",
                "abreviation": "team_abbreviation",
                "lieu": "location",
                "region": "region"
            }
        },
        "match": {
            "nom_fichier": "counter_strike_2/match.csv",
            "regle_victoire": {
                "methode": "comparaison",
                "stat_cible": "score",
                "logique": "plus_grand"
            },
            "mapping_base": {
                "date": "date",
                "type_match": "round",
                "format_sets": "best_of"
            },
            "performances": {
                "Equipe 1": {
                    "colonne_participant": "team_1",
                    "stats": {
                        "score": "score_team_1"
                    }
                },
                "Equipe 2": {
                    "colonne_participant": "team_2",
                    "stats": {
                        "score": "score_team_2"
                    }
                }
            }
