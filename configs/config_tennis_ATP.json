{
  "sport": "Tennis (ATP)",
  "fichiers": {
    "athlete": {
      "nom_fichier": "tennis/atp_players_2024.csv",
      "mapping": {
        "id_personne": "player_id",
        "nom": "name_last",         
        "prenom": "name_first",     
        "provenance": "ioc",
        "date_naissance": "dob",
        "taille": "height"
      }
    },
    "match": {
      "nom_fichier": "tennis/atp_matches_2024.csv",
      "mapping_base": {
          "id_match": "match_num",
          "date": "tourney_date",
          "lieu": "tourney_name",
          "type_match": "round",
          "surface": "surface",
          "niveau_tournoi": "tourney_level",
          "format_sets": "best_of"
      },
      "performances": {
        "Vainqueur": {
          "colonne_participant": "winner_id",
          "victoire_forcee": true,
          "stats": {
            "score": "score",
            "duree_match": "minutes",
            "aces": "w_ace",
            "double_fautes": "w_df",
            "points_service_total": "w_svpt",
            "premiers_services_reussis": "w_1stIn",
            "points_gagnes_1er_serve": "w_1stWon",
            "points_gagnes_2eme_serve": "w_2ndWon",
            "jeux_de_service": "w_SvGms",
            "balles_de_break_sauvees": "w_bpSaved",
            "balles_de_break_concedees": "w_bpFaced"
          }
        },
        "Perdant": {
          "colonne_participant": "loser_id",
          "victoire_forcee": false,
          "stats": {
            "score": "score",
            "duree_match": "minutes",
            "aces": "l_ace",
            "double_fautes": "l_df",
            "points_service_total": "l_svpt",
            "premiers_services_reussis": "l_1stIn",
            "points_gagnes_1er_serve": "l_1stWon",
            "points_gagnes_2eme_serve": "l_2ndWon",
            "jeux_de_service": "l_SvGms",
            "balles_de_break_sauvees": "l_bpSaved",
            "balles_de_break_concedees": "l_bpFaced"
          }
        }
      }
    }
  }
}