{
  "sport": "Tennis (ATP)",
  "type_format": "elimination",
  "cle_groupement": "tourney_name",
  "poids_rounds": {
    "F": 1,
    "SF": 2,
    "QF": 3,
    "R16": 4,
    "R32": 5,
    "R64": 6,
    "R128": 7
  },
  "fichiers": {
    "athlete": {
      "nom_fichier": "tennis/atp_players_2024.csv",
      "mapping": {
        "id_personne": "player_id",
        "nom": "name_last",
        "prenom": "name_first",
        "provenance": "ioc",
        "date_naissance": "dob",
        "taille": "height",
        "main_dominante": "hand"
      }
    },
    "match": {
      "nom_fichier": "tennis/atp_matches_2024.csv",
      "mapping_base": {
        "id_match": "match_num",
        "date": "tourney_date",
        "lieu": "tourney_name",
        "type_match": "round",
        "surface": "surface",
        "niveau_tournoi": "tourney_level",
        "format_sets": "best_of",
        "id_tournoi": "tourney_id",
        "taille_tableau": "draw_size"
      },
      "performances": {
        "Vainqueur": {
          "colonne_participant": "winner_id",
          "victoire_forcee": true,
          "stats": {
            "score": "score",
            "duree_minutes": "minutes",
            "aces": "w_ace",
            "double_fautes": "w_df",
            "points_service": "w_svpt",
            "premiers_services_reussis": "w_1stIn",
            "points_gagnes_1er_service": "w_1stWon",
            "points_gagnes_2eme_service": "w_2ndWon",
            "jeux_service_tenus": "w_SvGms",
            "balles_break_sauvees": "w_bpSaved",
            "balles_break_concedees": "w_bpFaced"
          }
        },
        "Perdant": {
          "colonne_participant": "loser_id",
          "victoire_forcee": false,
          "stats": {
            "score": "score",
            "duree_minutes": "minutes",
            "aces": "l_ace",
            "double_fautes": "l_df",
            "points_service": "l_svpt",
            "premiers_services_reussis": "l_1stIn",
            "points_gagnes_1er_service": "l_1stWon",
            "points_gagnes_2eme_service": "l_2ndWon",
            "jeux_service_tenus": "l_SvGms",
            "balles_break_sauvees": "l_bpSaved",
            "balles_break_concedees": "l_bpFaced"
          }
        }
      }
    }
  }
}